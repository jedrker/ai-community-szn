---
export const prerender = true;

import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import SpeakerCard from "../../components/SpeakerCard.astro";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formattedDate = event.data.date.toLocaleDateString("pl-PL", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const speakers = await Promise.all(
  event.data.speakers.map((id: string) => getEntry("speakers", id))
);
const validSpeakers = speakers.filter(Boolean);

const materialSpeakerIds = event.data.materials
  .map((m) => m.speaker)
  .filter(Boolean) as string[];
const materialSpeakers = await Promise.all(
  materialSpeakerIds.map((id) => getEntry("speakers", id))
);
const speakerNameMap = Object.fromEntries(
  materialSpeakers.filter(Boolean).map((s) => [s!.id, s!.data.name])
);

const partners =
  event.data.partners.length > 0
    ? event.data.partners
    : event.data.partner
      ? [event.data.partner]
      : [];
---

<BaseLayout title={event.data.title}>
  <Navbar slot="navbar" />

  {event.data.cover && (
    <img src={event.data.cover} alt={event.data.title} class="w-full h-64 md:h-80 object-cover" />
  )}

  <article class="max-w-4xl mx-auto px-6 py-12">
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-sm text-brand-purple">{formattedDate}</span>
        <span class="text-sm text-text-secondary">· {event.data.time}</span>
        <span class="text-sm text-text-secondary">
          · {event.data.location}
        </span>
      </div>
      <h1 class="text-4xl font-bold mb-4">{event.data.title}</h1>
      {
        event.data.lumaEventId && (
          <a
            href={event.data.lumaUrl}
            class="luma-checkout--button"
            data-luma-action="checkout"
            data-luma-event-id={event.data.lumaEventId}
          >
            Zarejestruj się na wydarzenie
          </a>
        )
      }
    </header>

    {partners.length > 0 && (
      <div class="flex items-center gap-3 mb-8 text-sm text-text-secondary">
        <span>{partners.length > 1 ? "Partnerzy wydarzenia:" : "Partner wydarzenia:"}</span>
        {
          partners.map((partner) => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:opacity-80 transition-opacity"
            >
              <img
                src={partner.logo}
                alt={partner.name}
                class="h-6"
              />
            </a>
          ))
        }
      </div>
    )}

    <div class="prose prose-invert max-w-none mb-12">
      <Content />
    </div>

    {
      validSpeakers.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-6">Prelegenci</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {validSpeakers.map(
              (speaker) =>
                speaker && (
                  <SpeakerCard
                    name={speaker.data.name}
                    role={speaker.data.role}
                    company={speaker.data.company}
                    photo={speaker.data.photo}
                    slug={speaker.id}
                  />
                )
            )}
          </div>
        </section>
      )
    }

    {
      event.data.materials.length > 0 && (
        <section class="mb-12">
          <h2 class="text-2xl font-bold mb-6">Materiały do pobrania</h2>
          <div class="space-y-3">
            {event.data.materials.map((material) => (
              <a
                href={material.file}
                download
                class="flex items-center gap-4 p-4 bg-surface-secondary border border-surface-border rounded-lg hover:border-brand-purple/50 transition-colors group"
              >
                <div class="flex-shrink-0 w-10 h-10 bg-brand-purple/10 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-brand-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="min-w-0">
                  <p class="text-sm font-medium text-white group-hover:text-brand-purple transition-colors truncate">
                    {material.title}
                  </p>
                  {material.speaker && speakerNameMap[material.speaker] && (
                    <p class="text-xs text-text-secondary">{speakerNameMap[material.speaker]}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {
      event.data.photos.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-6">Galeria</h2>
          <div id="photo-gallery" class="grid grid-cols-2 md:grid-cols-3 gap-3">
            {event.data.photos.slice(0, 12).map((photo: string, i: number) => (
              <a
                href={photo}
                class="gallery-thumb block aspect-[4/3] overflow-hidden rounded-lg"
                data-photo-index={i}
              >
                <img
                  src={photo}
                  alt={`${event.data.title} — zdjęcie ${i + 1}`}
                  class="w-full h-full object-cover hover:opacity-80 transition-opacity"
                  loading="lazy"
                />
              </a>
            ))}
          </div>
          {event.data.photos.length > 12 && (
            <div id="load-more-wrapper" class="text-center mt-8">
              <button
                id="load-more-photos"
                class="bg-surface-secondary border border-surface-border hover:border-brand-purple/50 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
              >
                Pokaż więcej ({event.data.photos.length - 12} pozostałych)
              </button>
            </div>
          )}
          <script is:inline define:vars={{ allPhotos: event.data.photos, eventTitle: event.data.title }}>
            window.__galleryPhotos = allPhotos;
            window.__galleryTitle = eventTitle;
          </script>
        </section>
      )
    }
  </article>

  <Footer slot="footer" />
</BaseLayout>

<script id="luma-checkout" src="https://embed.lu.ma/checkout-button.js"></script>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
<script is:inline src="https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js"></script>
<script is:inline>
  document.addEventListener("DOMContentLoaded", function () {
    var photos = window.__galleryPhotos || [];
    var title = window.__galleryTitle || "";
    if (!photos.length) return;

    var BATCH = 12;
    var shown = BATCH;
    var gallery = document.getElementById("photo-gallery");
    var btn = document.getElementById("load-more-photos");
    var wrapper = document.getElementById("load-more-wrapper");

    // Build slides array with ALL photos for lightbox
    var slides = photos.map(function (photo, i) {
      return { href: photo, type: "image", alt: title + " — zdjęcie " + (i + 1) };
    });

    var lightbox = GLightbox({
      elements: slides,
      touchNavigation: true,
      loop: true,
    });

    // Clicking a thumbnail opens lightbox at that index
    gallery.addEventListener("click", function (e) {
      var link = e.target.closest("a[data-photo-index]");
      if (!link) return;
      e.preventDefault();
      var index = parseInt(link.dataset.photoIndex, 10);
      lightbox.openAt(index);
    });

    function addBatch() {
      var end = Math.min(shown + BATCH, photos.length);
      for (var i = shown; i < end; i++) {
        var a = document.createElement("a");
        a.href = photos[i];
        a.className = "gallery-thumb block aspect-[4/3] overflow-hidden rounded-lg";
        a.dataset.photoIndex = i;
        var img = document.createElement("img");
        img.src = photos[i];
        img.alt = title + " — zdjęcie " + (i + 1);
        img.className = "w-full h-full object-cover hover:opacity-80 transition-opacity";
        img.loading = "lazy";
        a.appendChild(img);
        gallery.appendChild(a);
      }
      shown = end;

      if (wrapper) {
        var remaining = photos.length - shown;
        if (remaining <= 0) {
          wrapper.remove();
        } else {
          btn.textContent = "Pokaż więcej (" + remaining + " pozostałych)";
        }
      }
    }

    if (btn) {
      btn.addEventListener("click", addBatch);
    }
  });
</script>
