---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import EventCard from "../components/EventCard.astro";
import EmailSignup from "../components/EmailSignup.astro";

const allEvents = await getCollection("events");
const sortedEvents = allEvents.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const upcomingEvent = sortedEvents.find((e) => e.data.status === "upcoming");
const pastEvents = sortedEvents
  .filter((e) => e.data.status === "past")
  .slice(0, 4);
---

<BaseLayout title="Strona główna">
  <Navbar slot="navbar" />

  <HeroSection
    event={
      upcomingEvent
        ? {
            title: upcomingEvent.data.title,
            date: upcomingEvent.data.date,
            time: upcomingEvent.data.time,
            location: upcomingEvent.data.location,
            lumaUrl: upcomingEvent.data.lumaUrl,
          }
        : undefined
    }
  />

  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="bg-gradient-to-br from-brand-purple/10 via-surface-secondary to-brand-purple/5 border border-brand-purple/20 rounded-2xl p-8 md:p-12 text-center">
      {
        upcomingEvent ? (
          <>
            <p class="text-xs uppercase tracking-[3px] text-brand-purple mb-4">Nadchodzące wydarzenie</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">{upcomingEvent.data.title}</h2>
            <p class="text-text-secondary max-w-2xl mx-auto mb-8 leading-relaxed">
              {upcomingEvent.data.description}
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href={upcomingEvent.data.lumaUrl}
                class="luma-checkout--button inline-flex items-center gap-2 bg-brand-purple hover:bg-brand-purple-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
                data-luma-action="checkout"
                data-luma-event-id={upcomingEvent.data.lumaEventId}
              >
                Zarejestruj się na wydarzenie
              </a>
              <a
                href="/wydarzenia"
                class="inline-flex items-center gap-2 bg-surface-secondary border border-surface-border hover:border-brand-purple/50 text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
              >
                Zobacz szczegóły wydarzenia
              </a>
            </div>
          </>
        ) : (
          <>
            <p class="text-xs uppercase tracking-[3px] text-brand-purple mb-4">Kolejny meetup</p>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">W przygotowaniu</h2>
            <p class="text-text-secondary max-w-2xl mx-auto mb-8 leading-relaxed">
              Pracujemy nad programem kolejnego spotkania. Śledź nas, żeby nie przegapić zapisów.
            </p>
            <a
              href="#email-signup-form"
              class="inline-flex items-center gap-2 bg-brand-purple hover:bg-brand-purple-dark text-white font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
            >
              Zapisz się do newslettera →
            </a>
          </>
        )
      }
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl font-bold mb-6">Dlaczego warto dołączyć?</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-surface-secondary border border-surface-border rounded-lg p-6">
        <h3 class="text-lg font-semibold mb-2">Realne wdrożenia AI</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Żadnych slajdów z teorią. Nasi prelegenci dzielą się doświadczeniami z produkcji – od codingu z AI, przez bezpieczeństwo agentów, po wdrożenia GenAI w dużych organizacjach.
        </p>
      </div>
      <div class="bg-surface-secondary border border-surface-border rounded-lg p-6">
        <h3 class="text-lg font-semibold mb-2">Otwarta społeczność</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Developerzy, founderzy, managerowie i entuzjaści AI ze Szczecina i okolic. Niezależnie czy wdrażasz LLM-y w produkcji, budujesz produkty z AI, czy dopiero zaczynasz – tu jest Twoje miejsce.
        </p>
      </div>
      <div class="bg-surface-secondary border border-surface-border rounded-lg p-6">
        <h3 class="text-lg font-semibold mb-2">Wiedza i networking</h3>
        <p class="text-text-secondary text-sm leading-relaxed">
          Prezentacje z Q&A, open mic i czas na rozmowy. Spotykamy się regularnie w Szczecinie – każdy meetup to nowi prelegenci, świeże tematy i okazja do nawiązania wartościowych kontaktów.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl font-bold">Ostatnie wydarzenia</h2>
      <a
        href="/wydarzenia"
        class="text-sm text-brand-purple hover:text-brand-purple-light transition-colors"
      >
        Zobacz wszystkie →
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {
        pastEvents.map((event) => (
          <EventCard
            title={event.data.title}
            date={event.data.date}
            slug={event.id}
            description={event.data.description}
            speakerCount={event.data.speakers.length}
            photoCount={event.data.photos.length}
            status={event.data.status}
            cover={event.data.cover}
          />
        ))
      }
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-10">
      Rozwijaj kompetencje AI z programami BRAVE
    </h2>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
      <a
        href="https://www.aidevs.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/aidevs.webp"
          alt="AI_devs 4"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.aimanagers.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/ai-managers.webp"
          alt="AI_Managers"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.10xdevs.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/10xdevs.webp"
          alt="10xDevs"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.aiproductheroes.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/ai-product-heroes.webp"
          alt="AI Product Heroes"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
      <a
        href="https://aimarketers.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/ai-marketers.webp"
          alt="AI_Marketers"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
      <a
        href="https://www.aisales.pl/"
        target="_blank"
        rel="noopener noreferrer"
        class="block rounded-xl overflow-hidden border border-surface-border hover:border-brand-purple/50 transition-all hover:scale-[1.02]"
      >
        <img
          src="/images/brave-courses/ai-sales.webp"
          alt="AI_Sales"
          class="w-full aspect-[4/5] object-cover"
          loading="lazy"
        />
      </a>
    </div>
  </section>

  <EmailSignup />

  <Footer slot="footer" />
</BaseLayout>

<script id="luma-checkout" src="https://embed.lu.ma/checkout-button.js"></script>
