<section class="border-t border-surface-border py-16 px-6">
  <div class="max-w-md mx-auto text-center">
    <h2 class="text-xl font-bold mb-2">Bądź na bieżąco</h2>
    <p class="text-text-secondary text-sm mb-6">
      Dołącz do newslettera – powiadomimy Cię o kolejnych meetupach i nowych prelegentach.
    </p>
    <form id="email-signup-form" class="flex gap-2">
      <input
        type="email"
        name="email"
        required
        placeholder="twoj@email.pl"
        class="flex-1 bg-surface-secondary border border-surface-border rounded-lg px-4 py-2.5 text-sm text-white placeholder:text-text-secondary focus:outline-none focus:border-brand-purple"
      />
      <button
        type="submit"
        id="email-signup-btn"
        class="bg-brand-purple hover:bg-brand-purple-dark text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Zapisz się
      </button>
    </form>
    <div id="signup-success" class="hidden mt-4 bg-green-900/30 border border-green-700/50 rounded-lg px-4 py-3">
      <p class="text-green-400 text-sm font-medium" id="signup-success-text"></p>
    </div>
    <p id="signup-error" class="text-sm mt-3 text-red-400 hidden"></p>
  </div>
</section>

<script>
  const form = document.getElementById(
    "email-signup-form"
  ) as HTMLFormElement;
  const btn = document.getElementById("email-signup-btn") as HTMLButtonElement;
  const successBox = document.getElementById("signup-success") as HTMLElement;
  const successText = document.getElementById("signup-success-text") as HTMLElement;
  const errorMsg = document.getElementById("signup-error") as HTMLElement;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Reset state
    successBox.classList.add("hidden");
    errorMsg.classList.add("hidden");

    // Loading state
    const originalText = btn.textContent;
    btn.textContent = "Zapisywanie...";
    btn.disabled = true;

    const formData = new FormData(form);

    try {
      const res = await fetch("/api/newsletter-signup", {
        method: "POST",
        body: formData,
      });
      const data = await res.json();

      if (res.ok) {
        successText.textContent = data.message;
        successBox.classList.remove("hidden");
        form.reset();
      } else {
        errorMsg.textContent = data.error || "Wystąpił błąd. Spróbuj ponownie.";
        errorMsg.classList.remove("hidden");
      }
    } catch {
      errorMsg.textContent = "Wystąpił błąd. Spróbuj ponownie.";
      errorMsg.classList.remove("hidden");
    } finally {
      btn.textContent = originalText;
      btn.disabled = false;
    }
  });
</script>
