---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brave AI Community Szczecin — spolecznosc AI w Szczecinie" } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Brave AI Community Szczecin</title>
  </head>
  <body
    class="bg-surface-primary text-text-primary font-archivo min-h-screen flex flex-col"
  >
    <slot name="navbar" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
